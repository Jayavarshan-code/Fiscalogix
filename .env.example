# ---------------------------------------------------------
# Fiscalogix: Enterprise Secrets Configuration (.env)
# ---------------------------------------------------------
# SECURITY WARNING: Never commit the actual .env file to git.
# This is a template showing the required API keys for production.

# --- 1. Weather API (Micro-Weather H3 Mapping) ---
# Source: OpenWeatherMap / NOAA National Weather API
OPENWEATHER_API_KEY="your_openweather_api_key_here"

# --- 2. Geopolitical Shock API (Conflict Zones) ---
# Source: ACLED (Armed Conflict Location & Event Data Project)
ACLED_API_KEY="your_acled_api_key_here"
ACLED_EMAIL="tenant_admin@fiscalogix.com"

# --- 3. Port Congestion API (Physical Queue Metrics) ---
# Source: MarineTraffic API
MARINETRAFFIC_API_KEY="your_marinetraffic_api_key_here"

# --- 4. Database & Infrastructure ---
POSTGRES_USER="admin"
POSTGRES_PASSWORD="secure_password_here"
POSTGRES_DB="fiscalogix"
REDIS_URL="redis://localhost:6379/0"
